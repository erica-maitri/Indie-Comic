# Hugging Face Access Token (Required for downloading gated visual models)
HF_TOKEN=your_huggingface_token_here

# LLM Selection & Configuration
# Supported providers: ollama, openai, gemini, anthropic
LLM_PROVIDER=ollama

# Ollama Settings
OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenAI Settings (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Gemini Settings (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Anthropic Settings (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Pipeline Dry-Run Control
# If set to true, disables actual visual model inference and uses mock generation
# to save VRAM and verify integration flow safely.
PIPELINE_DRY_RUN=true
